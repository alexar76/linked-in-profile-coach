# --- Secrets & env (never commit) ---
.env
.env.*
!.env.example
secrets/
*.pem
**/credentials.json
**/service-account*.json

# --- Local app data (SQLite DB on device / dev machine) ---
*.db
*.sqlite
*.sqlite3

# --- Release packages (built locally or in CI, attached to GitHub Releases) ---
ProfileCoach-*.zip
ProfileCoach-*.apk
ProfileCoach-*.dmg
ProfileCoach-*.aab
build/release/

# --- Python (icon / screenshot tools in tool/) ---

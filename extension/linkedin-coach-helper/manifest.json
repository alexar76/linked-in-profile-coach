{
  "manifest_version": 3,
  "name": "Profile Coach — Copy LinkedIn Section",
  "version": "1.0.0",
  "description": "Copy the current LinkedIn profile section with a header for Profile Coach import.",
  "permissions": ["clipboardWrite", "activeTab"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_title": "Copy section for Profile Coach",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
